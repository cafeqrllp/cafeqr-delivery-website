# ============================================================
# CafeQR Delivery Frontend — Environment Variables Template
# Copy this to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ============================================================

# --- Supabase (Test/Production differ — set per environment) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Firebase (Client SDK — safe to expose) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# --- Firebase Admin SDK (SERVER SIDE ONLY — never expose) ---
# Option A: JSON string of service account key
FIREBASE_ADMIN_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
# Option B: Individual fields (use if JSON has quoting issues in env)
# FIREBASE_ADMIN_PROJECT_ID=
# FIREBASE_ADMIN_CLIENT_EMAIL=
# FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- App Config ---
NEXT_PUBLIC_APP_URL=https://delivery.cafeqr.in
NEXT_PUBLIC_SUPPORT_PHONE=+919876543210

# --- Environment flag (test | production) ---
# Used by migration scripts to target the correct Supabase project
APP_ENV=test
